# Database
DATABASE_URL=postgresql://user:password@localhost:5432/youressaywriter

# JWT
JWT_SECRET=your_jwt_secret_key_here

# Stripe
STRIPE_PUBLIC_KEY=pk_test_your_key
STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
NEXT_PUBLIC_STRIPE_PUBLIC_KEY=pk_test_your_key

# AWS S3 (File Upload)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=youressaywriter-bucket

# Email (Resend)
RESEND_API_KEY=your_resend_api_key

# App URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# Analytics
NEXT_PUBLIC_GA_ID=G_XXXXX
NEXT_PUBLIC_FACEBOOK_PIXEL_ID=xxx
NEXT_PUBLIC_MICROSOFT_CLARITY_ID=xxx

# Tawk.to
NEXT_PUBLIC_TAWK_PROPERTY_ID=xxx
